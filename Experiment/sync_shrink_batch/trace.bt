kprobe:mb_cache_entry_create
{
  $c = (struct mb_cache*)arg0;
  printf("create: cnt=%d max=%d\n", $c->c_entry_count, $c->c_max_entries);
}

kprobe:mb_cache_shrink 
{ 
    printf("shrink nr_to_scan=%u\n", arg1); 
}

kprobe:mb_cache_entry_create
{
  $c = (struct mb_cache*)arg0;
  if ($c->c_entry_count >= $c->c_max_entries){
    printf(">= 1x threshold (will schedule worker)\n");
  }
  if ($c->c_entry_count >= 2*$c->c_max_entries) {
    printf(">= 2x threshold (SYNC path possible)\n");
  }
}

