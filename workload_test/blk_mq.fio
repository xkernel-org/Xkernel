[global]
# I/O引擎: 推荐使用io_uring以获得最高性能，libaio是备选
ioengine=io_uring
# 绕过文件系统缓存，直接测试块设备
direct=1
# 共享所有作业的设备和文件
group_reporting
# 测试时长
time_based
runtime=30s
# 预热时间，让设备达到稳定状态
ramp_time=10s
# 目标设备，请务必修改为你的高速NVMe SSD设备名
filename=/dev/nvme1n1

[high-iops-randread]
# 作业名称
name=high-iops-test
# 块大小: 使用4k小块来最大化IOPS
bs=4k
# I/O模式: 随机读取，通常能产生最高的IOPS
rw=randread
# 队列深度: 设置一个非常高的队列深度来确保设备始终有工作可做
iodepth=1024
numjobs=2
# 使用io_uring的SQPOLL特性，进一步降低延迟（如果内核支持）
sqthread_poll=1