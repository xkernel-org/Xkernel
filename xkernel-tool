#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCOPE_TABLE="/dev/shm/xkernel/scope_table"
CS_RAW="/dev/shm/xkernel/cs_raw"
CS_FILE="/dev/shm/xkernel/cs"

# Update status for a ConstID in the scope table
update_status() {
    local const_id="$1"
    local new_status="$2"
    if [ -f "$SCOPE_TABLE" ]; then
        awk -F'\t' -v OFS='\t' -v cid="$const_id" -v status="$new_status" '
            NR==1 { for(i=1;i<=NF;i++) { if($i=="ConstID") cid_col=i; if($i=="Status") st_col=i } }
            NR>1 && $cid_col==cid { $st_col=status }
            { print }
        ' "$SCOPE_TABLE" > "${SCOPE_TABLE}.tmp" && mv "${SCOPE_TABLE}.tmp" "$SCOPE_TABLE"
    fi
}

# Update status for all entries matching a BPF file
update_status_by_file() {
    local bpf_file="$1"
    local new_status="$2"
    if [ -f "$SCOPE_TABLE" ]; then
        awk -F'\t' -v OFS='\t' -v bpf="$bpf_file" -v status="$new_status" '
            NR==1 { for(i=1;i<=NF;i++) { if($i=="BPF_File") bf_col=i; if($i=="Status") st_col=i } }
            NR>1 && $bf_col==bpf { $st_col=status }
            { print }
        ' "$SCOPE_TABLE" > "${SCOPE_TABLE}.tmp" && mv "${SCOPE_TABLE}.tmp" "$SCOPE_TABLE"
    fi
}

# Update status for all entries
update_all_status() {
    local new_status="$1"
    if [ -f "$SCOPE_TABLE" ]; then
        awk -F'\t' -v OFS='\t' -v status="$new_status" '
            NR==1 { for(i=1;i<=NF;i++) { if($i=="Status") st_col=i } print; next }
            NF>=st_col { $st_col=status; print }
        ' "$SCOPE_TABLE" > "${SCOPE_TABLE}.tmp" && mv "${SCOPE_TABLE}.tmp" "$SCOPE_TABLE"
    fi
}

# Resolve function address from /proc/kallsyms
resolve_func_addr() {
    local func_name="$1"
    # Get the address of the function from kallsyms (requires root)
    local addr
    addr=$(sudo grep -E "^[0-9a-f]+ [tT] ${func_name}$" /proc/kallsyms 2>/dev/null | head -1 | awk '{print $1}')
    if [ -n "$addr" ]; then
        echo "0x$addr"
    else
        echo ""
    fi
}

# Generate CS file from cs_raw for specified ConstIDs
generate_cs_file() {
    local const_ids="$1"  # Comma-separated ConstIDs

    if [ ! -f "$CS_RAW" ]; then
        echo "Warning: CS_RAW file not found at $CS_RAW"
        return 1
    fi

    # Clear existing CS file
    > "$CS_FILE"

    # Parse const_ids into array
    IFS=',' read -ra CID_ARRAY <<< "$const_ids"

    # Read cs_raw and generate cs file for matching ConstIDs
    # Format of cs_raw: ConstID\tFunctionName\tStartOffset\tEndOffset
    # Format of cs: function_name,function_address,soff,eoff
    tail -n +2 "$CS_RAW" | while IFS=$'\t' read -r cid func_name soff eoff; do
        # Check if this ConstID is in our list
        for target_cid in "${CID_ARRAY[@]}"; do
            if [ "$cid" = "$target_cid" ]; then
                # Resolve function address
                func_addr=$(resolve_func_addr "$func_name")
                if [ -n "$func_addr" ]; then
                    echo "${func_name},${func_addr},${soff},${eoff}" >> "$CS_FILE"
                else
                    echo "Warning: Could not resolve address for function $func_name"
                fi
                break
            fi
        done
    done

    if [ -s "$CS_FILE" ]; then
        echo "Generated CS file: $CS_FILE"
        return 0
    else
        echo "Warning: No CS entries generated"
        return 1
    fi
}

show_help() {
    echo "Usage: $0 <command> [options]"
    echo
    echo "Commands:"
    echo "  build     Generate BPF code from tests and compile"
    echo "  load      Load BPF kprobes for specified ConstIDs or files"
    echo "  unload    Unload all loaded BPF kprobes"
    echo "  table     Manage scope tables (list, query, delete, cs, ss)"
    echo "  trace     Trace the kernel logs"
    echo
    echo "Options for 'build':"
    echo "  --skip-gen    Skip running gen.sh (only run build_cs.py and make)"
    echo
    echo "Options for 'load':"
    echo "  <MODE>        0=Immediate, 1=Per-task, 2=Global"
    echo "  <IDs/files>   ConstIDs (e.g., 1,2) or BPF file paths"
    echo "  [timeout]     Optional timeout in seconds (for Mode 2)"
    echo
    echo "Options for 'table':"
    echo "  list                    List all scope table entries"
    echo "  query [filters]         Query entries"
    echo "  delete [filters|--all]  Delete entries"
    echo "  cs [--index N]          Show Critical Span entries"
    echo "  ss [--index N]          Show Symbolic State entries"
    echo
    echo "Examples:"
    echo "  $0 build                # Full build pipeline"
    echo "  $0 load 0 1             # Load ConstID 1 in Immediate mode"
    echo "  $0 table list           # List scope table"
    echo "  $0 table delete --all   # Clear all tables"
    echo "  $0 unload               # Unload all kprobes"
    echo
    exit 1
}

if [ $# -lt 1 ]; then
    show_help
fi

COMMAND=$1

if [ "$COMMAND" = "build" ]; then
    SKIP_GEN=false
    if [ "$2" = "--skip-gen" ]; then
        SKIP_GEN=true
    fi

    echo "=========================================="
    echo "Xkernel Build Pipeline"
    echo "=========================================="

    # Step 1: Run gen.sh (unless skipped)
    if [ "$SKIP_GEN" = false ]; then
        echo ""
        echo "[Step 1/3] Running gen.sh to generate Basic Block analysis..."
        echo "=========================================="
        cd "$SCRIPT_DIR/codegen" || exit 1
        if ! ./gen.sh; then
            echo "Error: gen.sh failed"
            exit 1
        fi
        cd "$SCRIPT_DIR" || exit 1
    else
        echo ""
        echo "[Step 1/3] Skipped gen.sh (--skip-gen)"
    fi

    # Step 2: Run build_cs.py
    echo ""
    echo "[Step 2/3] Running build_cs.py to generate BPF code..."
    echo "=========================================="
    cd "$SCRIPT_DIR/codegen" || exit 1
    if ! python3 build_cs.py; then
        echo "Error: build_cs.py failed"
        exit 1
    fi
    cd "$SCRIPT_DIR" || exit 1

    # Step 3: Compile BPF programs
    echo ""
    echo "[Step 3/3] Compiling BPF programs..."
    echo "=========================================="
    cd "$SCRIPT_DIR/bpf_kprobe" || exit 1
    if ! make -j"$(nproc)"; then
        echo "Error: BPF compilation failed"
        exit 1
    fi
    cd "$SCRIPT_DIR" || exit 1

    echo ""
    echo "=========================================="
    echo "Build completed successfully!"
    echo "=========================================="
    echo ""
    echo "Next steps:"
    echo "  $0 load <MODE> <ConstID>    # Load the BPF program"
    echo "  $0 unload                   # Unload when done"
    echo ""
    exit 0

elif [ "$COMMAND" = "load" ]; then
    if [ -z "$2" ] || [ -z "$3" ]; then
        echo "Missing argument: [0:Immediate, 1:Per-task, 2:Global] [ConstID1,ConstID2,...] or [file1,file2,...] [Timeout seconds]"
        exit 1
    fi
    MODE=$2
    if [ "$MODE" -ne 0 ] && [ "$MODE" -ne 1 ] && [ "$MODE" -ne 2 ]; then
        echo "Invalid mode: $MODE"
        exit 1
    fi
    INPUT=$3
    if [ -z "$INPUT" ]; then
        echo "Missing argument: [ConstID1,ConstID2,...] or [file1,file2,...]"
        exit 1
    fi
    LOADER="./bpf_kprobe/kprobe_loader"
    if [ ! -f "$LOADER" ]; then
        echo "kprobe_loader not found at $LOADER"
        exit 1
    fi

    # Check if input is ConstID(s) or file path(s)
    # ConstID format: uint64_t (numeric, e.g., 1, 2, etc.)
    # File path format: contains '/' or ends with '.bpf.o'
    RESOLVED_FILES=""
    LOADED_CONST_IDS=()
    LOADED_BPF_FILES=()
    IFS=',' read -ra ITEMS <<< "$INPUT"
    for item in "${ITEMS[@]}"; do
        item=$(echo "$item" | xargs)  # trim whitespace
        if [[ "$item" =~ ^[0-9]+$ ]]; then
            # It's a ConstID (uint64_t), resolve from Scope Table
            if [ ! -f "$SCOPE_TABLE" ]; then
                echo "Error: Scope Table not found at $SCOPE_TABLE"
                exit 1
            fi
            
            # ConstID is uint64_t (numeric)
            CONST_ID="$item"
            
            # Read BPF_File from Scope Table
            BPF_FILE=$(awk -F'\t' -v const_id="$CONST_ID" '
                NR==1 { 
                    for(i=1; i<=NF; i++) {
                        if($i=="ConstID") constid_col=i
                        if($i=="BPF_File") bpf_col=i
                    }
                }
                NR>1 && $constid_col==const_id {
                    print $bpf_col
                    exit
                }
            ' "$SCOPE_TABLE")
            
            if [ -z "$BPF_FILE" ]; then
                echo "Error: ConstID $CONST_ID not found in Scope Table"
                exit 1
            fi
            
            # Build full path: bpf_kprobe/bpf/examples/BPF_FILE
            FULL_PATH="bpf_kprobe/bpf/examples/$BPF_FILE"
            if [ ! -f "$FULL_PATH" ]; then
                echo "Error: BPF file not found: $FULL_PATH (for ConstID $CONST_ID)"
                exit 1
            fi
            
            if [ -z "$RESOLVED_FILES" ]; then
                RESOLVED_FILES="$FULL_PATH"
            else
                RESOLVED_FILES="$RESOLVED_FILES,$FULL_PATH"
            fi
            LOADED_CONST_IDS+=("$CONST_ID")
        else
            # It's a file path, use as-is
            if [ ! -f "$item" ]; then
                echo "Error: File not found: $item"
                exit 1
            fi
            if [ -z "$RESOLVED_FILES" ]; then
                RESOLVED_FILES="$item"
            else
                RESOLVED_FILES="$RESOLVED_FILES,$item"
            fi
            # Extract BPF filename for status update
            LOADED_BPF_FILES+=("$(basename "$item")")
        fi
    done
    
    if [ -z "$RESOLVED_FILES" ]; then
        echo "Error: No valid files to load"
        exit 1
    fi

    # Generate CS file from cs_raw if we have ConstIDs
    if [ ${#LOADED_CONST_IDS[@]} -gt 0 ]; then
        CONST_IDS_STR=$(IFS=','; echo "${LOADED_CONST_IDS[*]}")
        echo "Generating CS file for ConstIDs: $CONST_IDS_STR"
        generate_cs_file "$CONST_IDS_STR"
    fi

    echo "Loading kfuncs module..."
    sudo insmod ./kernel_module/kfuncs/xk-kfuncs.ko kMode=$MODE
    
    echo "Successfully loading BPF Kprobes:"
    echo "  Files: $RESOLVED_FILES"
    sudo "$LOADER" --files "$RESOLVED_FILES" --pin
    STATUS=$?
    if [ $STATUS -ne 0 ]; then
        echo "Failed to load kprobes. You can try xkernel-tool unload and load again."
        exit $STATUS
    fi

    # Update status to "active" for loaded entries
    for cid in "${LOADED_CONST_IDS[@]}"; do
        update_status "$cid" "active"
    done
    for bpf in "${LOADED_BPF_FILES[@]}"; do
        update_status_by_file "$bpf" "active"
    done

    if [ "$MODE" -eq 2 ]; then
        echo "Loading global consistency module for transition..."
        timeout=$4

        if [ -z "$timeout" ]; then
            sudo insmod ./kernel_module/consistency/xk-consistency.ko
        else
            sudo insmod ./kernel_module/consistency/xk-consistency.ko kTimeout=$timeout
        fi

        echo "Check dmesg to see if the transition is successful."
    fi

elif [ "$COMMAND" = "unload" ]; then
    echo "Unloading global consistency module for transition (if loaded)..."
    sudo rmmod xk-consistency > /dev/null 2>&1

    echo "Unloading BPF Kprobes..."
    sudo rm -rf /sys/fs/bpf/xkernel

    # Give bpf tools time to detach the kprobes.
    sleep 2
    echo "Unloading kfuncs module..."
    sudo rmmod xk-kfuncs

    # Update status to "ready" for all entries
    update_all_status "ready"

    echo "Check dmesg to see if the transition is successful."

    exit 0
elif [ "$COMMAND" = "table" ]; then
    # Pass all remaining arguments to xkernel_table_manager.py
    shift  # Remove 'table' from arguments
    python3 "$SCRIPT_DIR/xkernel_table_manager.py" "$@"
    exit $?

elif [ "$COMMAND" = "trace" ]; then
    sudo bpftool prog tracelog
    exit 0
else
    show_help
fi

